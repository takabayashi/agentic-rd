# Copy to .env and adjust. `.env` is gitignored — never commit real secrets.
# Phase 0 needs no configuration; these are placeholders for later phases.

# --- Web app ---
# APP_PORT=8080

# --- Postgres (Phase 3) ---
# POSTGRES_DB=wiki
# POSTGRES_USER=wiki
# POSTGRES_PASSWORD=change-me

# --- Wikipedia ingest (Phase 4) ---
# WIKI_USER_AGENT=agentic-rd/0.0 (you@example.com)

# --- LLM / Ollama (Phase 6) ---
# OLLAMA_MODEL=llama3.2
# OLLAMA_ADDRESS=http://ollama:11434

# --- Classification (Phase 8) ---
# CONFIDENCE_THRESHOLD=0.7
