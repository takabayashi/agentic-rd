# Copy to .env and adjust. `.env` is gitignored — never commit real secrets.
# `.env` is optional: docker-compose.yml provides safe local defaults, so a
# fresh clone runs with `docker compose up` and no .env at all.

# --- Web app ---
# APP_PORT=8080

# --- Postgres (Phase 3) ---
# Compose builds the app's DATABASE_URL from these; change the password for any
# non-throwaway use. The app itself reads only DATABASE_URL (set by compose).
# POSTGRES_DB=wiki
# POSTGRES_USER=wiki
# POSTGRES_PASSWORD=change-me
# DATABASE_URL=postgresql://wiki:change-me@postgres:5432/wiki

# --- Wikipedia ingest (Phase 4) ---
# Wikipedia's SSE endpoint returns 403 without a descriptive User-Agent.
# docker-compose.yml provides a default; override with your contact info here.
# WIKI_USER_AGENT=agentic-rd/0.1 (you@example.com)

# --- LLM / Ollama (Phase 5) ---
# Model used for classification; docker-compose.yml pulls it on first start.
# Change OLLAMA_MODEL to any Ollama model (it will be pulled automatically).
# OLLAMA_ADDRESS points Connect at the Ollama server. On macOS, Docker Desktop
# runs the container CPU-only; for native GPU, run Ollama on the host and set
# OLLAMA_ADDRESS=http://host.docker.internal:11434.
# OLLAMA_MODEL=llama3.2
# Low-memory fallback (smaller, weaker — biases toward vandalism): qwen2.5:1.5b
# or qwen2.5:0.5b. Prefer llama3.2 where the VM has ~4 GB+.
# OLLAMA_ADDRESS=http://ollama:11434

# --- Classification escalation (Phase 6) ---
# CONFIDENCE_THRESHOLD=0.7
