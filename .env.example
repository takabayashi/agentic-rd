# Copy to .env and adjust. `.env` is gitignored — never commit real secrets.
# `.env` is optional: docker-compose.yml provides safe local defaults, so a
# fresh clone runs with `docker compose up` and no .env at all.

# --- Web app ---
# APP_PORT=8080
# How many recent rows the dashboard fetches before filtering/sorting in-app.
# RECENT_WINDOW_LIMIT=200

# --- Postgres (Phase 3) ---
# Credentials are fixed in docker-compose.yml (wiki / change-me) for local dev.
# Schema is applied on first boot via db/init.sql. To re-seed: docker compose down -v.

# --- Wikipedia ingest (connect-ingest + connect-enrich) ---
# Wikipedia's SSE endpoint returns 403 without a descriptive User-Agent.
# docker-compose.yml provides a default; override with your contact info here.
# WIKI_USER_AGENT=agentic-rd/0.1 (you@example.com)
# Diff enrichment (connect-enrich): truncate fetched diffs to this many chars,
# and cap MediaWiki compare-API calls per second (politeness).
# DIFF_MAX_CHARS=4000
# WIKI_RATE_LIMIT=10

# --- LLM / Ollama (connect-classify only) ---
# Model used for classification; docker-compose.yml pulls it on first start.
# Change OLLAMA_MODEL to any Ollama model (it will be pulled automatically).
# OLLAMA_ADDRESS points connect-classify at the Ollama server. On macOS, Docker
# Desktop runs the container CPU-only; for native GPU, run Ollama on the host
# and set OLLAMA_ADDRESS=http://host.docker.internal:11434.
# OLLAMA_MODEL=llama3.2
# Low-memory fallback (smaller, weaker — biases toward vandalism): qwen2.5:1.5b
# or qwen2.5:0.5b. Prefer llama3.2 where the VM has ~4 GB+.
# OLLAMA_ADDRESS=http://ollama:11434

# --- Classification escalation (connect-classify only) ---
# CONFIDENCE_THRESHOLD=0.7

# --- Content gate (connect-classify only) ---
# Skip the model for edits with no usable content: if the cleaned diff is
# shorter than DIFF_MIN_CHARS *and* |size_delta| < BLANKING_MIN_DELTA, the edit
# is labelled unclear (reason=empty_diff) without an LLM call. The size_delta
# guard keeps blanking / large removals going to the model.
# DIFF_MIN_CHARS=1
# BLANKING_MIN_DELTA=100

# --- Logging verbosity ---
# Connect log level for all three stages (ingest/enrich/classify): INFO default.
# Set DEBUG for component detail or TRACE for per-message flow.
# CONNECT_LOG_LEVEL=DEBUG
# Verbose Ollama request/inference logs (in the `ollama` container). 0=off, 1=on.
# OLLAMA_DEBUG=1
